# LinkedIn Developer App credentials
# Create your app at: https://www.linkedin.com/developers/apps
#
# RECOMMENDED: store credentials in the OS keychain instead of this file.
# Run `python -m linkedin_mcp setup` and you will never need this file.
#
# If you do use this file, credentials are auto-migrated to the keychain
# on the first `authenticate` call, after which you can delete this file.

LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Optional overrides (uncomment to use)
# LINKEDIN_REDIRECT_PORT=8919
# LINKEDIN_TOKEN_FILE=~/.linkedin_mcp_token.json
# LINKEDIN_SESSION_FILE=~/.linkedin_mcp_session.json
# LINKEDIN_BROWSER_DIR=~/.linkedin_mcp_browser
